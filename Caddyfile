ecotron.co.in, www.ecotron.co.in {
    # API Proxy (preserve path)
    handle /analyze* {
        reverse_proxy api:8000 {
            transport http {
                read_timeout 600s
                write_timeout 600s
            }
        }
    }

    handle /admin* {
        reverse_proxy api:8000
    }

    handle /health* {
        reverse_proxy api:8000
    }

    handle /blogs* {
        reverse_proxy api:8000
    }

    handle /api/blog-data* {
        reverse_proxy api:8000
    }

    handle /status* {
        reverse_proxy api:8000 {
            transport http {
                read_timeout 600s
                write_timeout 600s
            }
        }
    }

    handle /static* {
        reverse_proxy api:8000
    }

    # Catch-all for React Frontend
    handle {
        reverse_proxy trading-frontend:80
    }

    encode gzip
}
