FROM python:3.13-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install uv directly into /usr/local/bin
RUN curl -LsSf https://astral.sh/uv/install.sh | BINDIR=/usr/local/bin sh

# Copy project files
COPY . .

# Install dependencies using the absolute path to uv just in case
RUN /usr/local/bin/uv pip install --system -e .
RUN /usr/local/bin/uv pip install --system fastapi uvicorn python-dotenv

# Run the API server
CMD ["python", "server.py"]
