FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install uv using pip
RUN pip install uv

# Copy project files
COPY . .

# Install dependencies
RUN pip install -e .
RUN pip install fastapi uvicorn python-dotenv motor slowapi pymongo pandas

# Run the API server
CMD ["python", "server.py"]
