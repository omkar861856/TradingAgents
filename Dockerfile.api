FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install uv using pip
RUN pip install uv

# Copy project files
COPY . .

# Download Tailwind CLI (Linux x64)
RUN curl -sLO https://github.com/tailwindlabs/tailwindcss/releases/latest/download/tailwindcss-linux-x64 \
    && chmod +x tailwindcss-linux-x64 \
    && mv tailwindcss-linux-x64 /usr/local/bin/tailwindcss

# Compile CSS
RUN mkdir -p static && tailwindcss -i ./static/input.css -o ./static/dist.css --config ./tailwind.config.js --minify

# Install dependencies
RUN pip install -e .
RUN pip install fastapi uvicorn python-dotenv motor slowapi pymongo pandas

# Run the API server
CMD ["python", "server.py"]
